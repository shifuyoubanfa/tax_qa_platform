# ============================================================================
# tax_qa_platform 环境变量示例文件
# 用法：复制本文件为 .env （cp .env.example .env），按实际环境填写后即可被 settings 读取。
# 说明：
#   - 变量名全大写，与 config/settings.py 里的小写字段一一对应（pydantic-settings 大小写不敏感）。
#   - 所有密钥/口令默认留空，必须自行填写，切勿把真实 key 提交进仓库。
#   - host 默认 localhost、端口给标准值，保证本机开发可直接起服务（连接均为惰性，缺 infra 也能 import/启动）。
# ============================================================================

# ---------------- 应用与日志 ----------------
APP_HOST=0.0.0.0                       # 服务监听网卡，0.0.0.0 对外可访问；只本机访问可填 127.0.0.1
APP_PORT=8000                          # 服务端口
LOG_LEVEL=INFO                         # 日志级别：DEBUG/INFO/WARNING/ERROR（INFO 及以上必输出）
LOG_DIR=logs                           # 日志目录（相对项目根，运行时自动创建，按 20MB×5 滚动）

# ---------------- 大模型 LLM（OpenAI 兼容协议） ----------------
LLM_BASE_URL=http://localhost:8000/v1  # OpenAI 兼容 API 基础地址（千问/DeepSeek/vLLM 等均可）
LLM_API_KEY=                           # API 密钥（务必通过本文件注入，勿硬编码）
LLM_MODEL=qwen2.5-32b-instruct         # 默认对话模型名
LLM_TEMPERATURE=0.1                    # 采样温度，低温保证税务问答确定性
LLM_TIMEOUT=60                         # 单次请求超时（秒）
LLM_MAX_TOKENS=2048                    # 单次生成最大 token 数
LLM_DISABLE_THINKING=false             # 仅千问(Qwen3)系列设 true(关思考链)；OpenAI/DeepSeek 必须 false，否则未知参数报400

# ---------------- Embedding 向量化（http / local 两种模式） ----------------
EMBEDDING_MODE=http                    # http=调远程嵌入服务；local=本地 FlagEmbedding bge-m3
EMBEDDING_BASE_URL=http://localhost:9001  # http 模式的嵌入服务地址
EMBEDDING_API_KEY=                     # http 模式鉴权 key（服务需要时填）
EMBEDDING_MODEL=bge-m3                  # 嵌入模型名
EMBEDDING_DIM=1024                     # 向量维度（bge-m3 为 1024，须与 Milvus 集合一致）
EMBEDDING_LOCAL_PATH=                   # local 模式的本地模型权重路径（如 /models/bge-m3）
EMBEDDING_USE_SPARSE=true               # 是否同时产出稀疏向量（混合召回需要 true）

# ---------------- Reranker 重排（仅本地 FlagReranker，无 http 服务） ----------------
RERANKER_MODEL=bge-reranker-v2-m3       # 重排模型名
RERANKER_LOCAL_PATH=                    # 本地模型权重路径（FlagReranker 加载）

# ---------------- Milvus 稠密向量库（文档稠密召回） ----------------
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USER=                            # 开启鉴权时填写
MILVUS_PASSWORD=
MILVUS_DB=default                       # Milvus 数据库名
MILVUS_DOC_COLLECTION=tax_doc           # 文档稠密向量集合名

# ---------------- Elasticsearch 全文/BM25 稀疏召回 ----------------
ES_HOSTS=http://localhost:9200          # 多个地址用英文逗号分隔
ES_USER=                                # 开启安全认证时填写
ES_PASSWORD=
ES_DOC_INDEX=tax_doc                    # 文档全文索引名

# ---------------- Qdrant 数仓元数据向量库（Text2SQL schema linking 用） ----------------
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=                         # Qdrant Cloud 等需要时填写
QDRANT_META_COLLECTION=schema_meta      # 表/字段元数据向量集合名

# ---------------- MySQL 经营/财税数仓（Text2SQL 执行库，只读 SELECT） ----------------
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DB=tax_dw                         # 数仓库名
MYSQL_CHARSET=utf8mb4                   # 字符集，utf8mb4 支持完整中文

# ---------------- MongoDB 多轮会话历史 ----------------
MONGO_URI=mongodb://localhost:27017
MONGO_DB=tax_qa
MONGO_HISTORY_COLLECTION=chat_history   # 会话历史集合名

# ---------------- MinIO 多模态图片对象存储 ----------------
MINIO_ENDPOINT=localhost:9000           # 注意：填 host:port，不带 http(s):// 前缀
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=tax-doc-images             # 存放文档图片的桶名
MINIO_SECURE=false                      # true 走 https，本地开发一般 false

# ---------------- MinerU 文档解析（http / local） ----------------
MINERU_MODE=http                        # http=调远程解析服务；local=本地 magic-pdf
MINERU_BASE_URL=http://localhost:9003   # http 模式的解析服务地址
MINERU_TOKEN=                           # 解析服务鉴权 token

# ---------------- MCP Model Context Protocol（可选外部工具） ----------------
MCP_ENABLED=false                       # false 时 McpClient 安全降级（不真连），无网络也能跑；true 时结构化查询经 MCP 调工具
MCP_TRANSPORT=stdio                     # stdio=本地子进程拉起自带 MCP server；sse=连远程 MCP server（如百炼）
MCP_SERVER_COMMAND=python -m app.mcp.server  # stdio 模式专用：启动自带 MCP server 的命令（被 MCP 客户端拉起为子进程）
MCP_SSE_URL=                            # sse 模式专用：远程 MCP server 的 SSE 地址；stdio 模式留空
MCP_BAILIAN_BASE_URL=                   # 百炼 MCP 服务地址（sse 模式连百炼时可用）
MCP_BAILIAN_API_KEY=                    # 百炼 MCP 鉴权 key

# ---------------- 检索链路通用阈值 ----------------
RECALL_TOPK=50                          # 单库粗召回条数
FINE_TOPK=20                            # 精排后保留条数
RERANK_TOPK=5                           # 重排后最终保留条数（即最终参考片段数）
